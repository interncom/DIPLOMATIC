{
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node", "bun"],
    "skipLibCheck": true
  },
  "include": [
    "server.ts",
    "../shared"
  ]
}