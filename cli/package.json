{
  "name": "@interncom/diplomatic-cli-internal",
  "version": "0.1.5",
  "type": "module",
  "description": "CLI utilities for DIPLOMATIC",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "diplomatic-host": "./bin/host.js"
  },
  "scripts": {
    "tsc": "tsc",
    "build": "bun run tsc && cp dist/cli/src/index.d.ts dist/index.d.ts && bun run esbuild.mjs",
    "test": "deno test --allow-net --allow-ffi --allow-env ../deno/"
  },
