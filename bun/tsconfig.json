{
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "types": ["bun", "node"],
    "skipLibCheck": true
  },
  "include": [
    "src",
    "../shared"
  ]
}