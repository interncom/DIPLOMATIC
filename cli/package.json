  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.14.11",
    "esbuild": "0.21.5",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@noble/hashes": "1.8.0",
    "libsodium-wrappers": "0.8.2"
  }
}
